[submodule "libs/sdk"]
	path = libs/sdk
	url = https://github.com/ADRFranklin/samp-plugin-sdk
[submodule "libs/date"]
	path = libs/date
	url = https://github.com/HowardHinnant/date.git
[submodule "libs/fmt"]
	path = libs/fmt
	url = https://github.com/fmtlib/fmt.git
[submodule "libs/cmake-conan"]
	path = libs/cmake-conan
	url = https://github.com/ADRFranklin/samp-conan-cmake
[submodule "libs/log-core"]
	path = libs/log-core
	url = https://github.com/ADRFranklin/samp-log-core.git
[submodule "libs/cmake"]
	path = libs/cmake
	url = https://github.com/ADRFranklin/samp-cmake
